# ─── Entornos y secretos ───────────────────────────────────────────
.env
.env.*
*.env

# ─── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/

# ─── Jupyter ───────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── Datos crudos (no versionar archivos sensibles o pesados) ──────
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.xls
data/raw/*.parquet
data/raw/*.json

# ─── Entornos virtuales ────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ─── IDEs y editores ───────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.spyderproject
.spyproject

# ─── Sistema operativo ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Logs y temporales ─────────────────────────────────────────────
*.log
*.tmp
*.temp
*.swp
*.swo

# ─── Cobertura y tests ─────────────────────────────────────────────
.coverage
.pytest_cache/
htmlcov/

# ─── Outputs grandes (mantener carpeta, ignorar archivos pesados) ───
outputs/graficos/*.png
outputs/graficos/*.jpg
outputs/graficos/*.pdf
